{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": false,
    "sourceMap": false,
    "outDir": ".build",
    "rootDir": "lib",
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": ["lib/**/*.core.ts"],
  "exclude": ["node_modules", "dist", "test"]
}
